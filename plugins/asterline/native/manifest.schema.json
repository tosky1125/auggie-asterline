{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://asterline.local/schemas/native-sbom-v1.json",
  "title": "Asterline native asset SBOM",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "components"],
  "properties": {
    "$schema": { "type": "string" },
    "schemaVersion": { "const": 1 },
    "components": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/component" }
    }
  },
  "$defs": {
    "component": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "version", "license", "source", "probe", "assets"],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
        "version": { "type": "string", "minLength": 1 },
        "license": { "$ref": "#/$defs/license" },
        "source": { "$ref": "#/$defs/source" },
        "probe": { "$ref": "#/$defs/probe" },
        "assets": {
          "type": "object",
          "minProperties": 1,
          "propertyNames": { "pattern": "^(darwin|linux|win32)-(arm64|x64)$" },
          "additionalProperties": { "$ref": "#/$defs/asset" }
        }
      }
    },
    "license": {
      "type": "object",
      "additionalProperties": false,
      "required": ["spdx", "provenance"],
      "properties": {
        "spdx": { "type": "string", "minLength": 1 },
        "provenance": { "type": "string", "format": "uri", "pattern": "^https://" }
      }
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repository", "revision"],
      "properties": {
        "repository": { "type": "string", "format": "uri", "pattern": "^https://" },
        "revision": { "type": "string", "pattern": "^[0-9a-f]{40}$" }
      }
    },
    "probe": {
      "type": "object",
      "additionalProperties": false,
      "required": ["args", "expectedExit", "expectedStdout", "timeoutMs"],
      "properties": {
        "args": { "type": "array", "items": { "type": "string" }, "maxItems": 8 },
        "expectedExit": { "type": "integer", "minimum": 0, "maximum": 255 },
        "expectedStdout": { "type": "string", "minLength": 1 },
        "timeoutMs": { "type": "integer", "minimum": 100, "maximum": 30000 }
      }
    },
    "asset": {
      "type": "object",
      "additionalProperties": false,
      "required": ["archive", "executable", "executableSha256", "sha256", "url"],
      "properties": {
        "archive": { "enum": ["tar.gz", "tgz", "zip"] },
        "executable": { "type": "string", "minLength": 1 },
        "executableSha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
        "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
        "url": { "type": "string", "format": "uri", "pattern": "^https://" }
      }
    }
  }
}
