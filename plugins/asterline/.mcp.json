{
  "mcpServers": {
    "ast_grep": {
      "command": "bash",
      "args": [
        "-lc",
        "exec node \"$HOME/.augment/plugins/marketplaces/auggie-asterline/plugins/asterline/mcp/ast_grep/dist/cli.js\" mcp"
      ]
    },
    "grep_app": {
      "type": "http",
      "url": "https://mcp.grep.app"
    },
    "context7": {
      "type": "http",
      "url": "https://mcp.context7.com/mcp"
    },
    "lsp": {
      "command": "bash",
      "args": [
        "-lc",
        "exec node \"$HOME/.augment/plugins/marketplaces/auggie-asterline/plugins/asterline/mcp/lsp/dist/cli.js\" mcp"
      ]
    },
    "codegraph": {
      "command": "bash",
      "args": [
        "-lc",
        "exec node \"$HOME/.augment/plugins/marketplaces/auggie-asterline/plugins/asterline/mcp/codegraph/dist/serve.js\""
      ]
    }
  }
}
