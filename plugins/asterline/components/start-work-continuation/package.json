{
	"name": "@code-yeongyu/asterline-start-work-continuation",
	"version": "4.17.1",
	"description": "Asterline Stop hook continuation injector for Auggie run-plan work.",
	"type": "module",
	"license": "MIT",
	"homepage": "https://github.com/code-yeongyu/asterline-start-work-continuation",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/code-yeongyu/asterline-start-work-continuation.git"
	},
	"bugs": {
		"url": "https://github.com/code-yeongyu/asterline-start-work-continuation/issues"
	},
	"keywords": [
		"asterline",
		"asterline-plugin",
		"run-plan",
		"continuation",
		"hooks",
		"boulder"
	],
	"bin": {
		"asterline-run-plan-continuation": "./dist/cli.js"
	},
	"scripts": {
		"build": "tsc -p tsconfig.build.json",
		"test": "vitest --run",
		"test:watch": "vitest",
		"typecheck": "tsc --noEmit",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"check": "tsc --noEmit && biome check . && npm run build"
	},
	"files": [
		"dist",
		"directive.md",
		"hooks",
		"README.md",
		"LICENSE",
		"NOTICE"
	],
	"devDependencies": {
		"@biomejs/biome": "2.4.16",
		"@types/node": "^25.9.3",
		"typescript": "^6.0.3",
		"vitest": "^4.1.8"
	},
	"engines": {
		"node": ">=20.0.0"
	}
