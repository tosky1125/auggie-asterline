{
	"name": "@code-yeongyu/asterline-rules",
	"version": "4.17.1",
	"description": "Asterline plugin that injects project rule files into model context through lifecycle hooks.",
	"type": "module",
	"license": "MIT",
	"homepage": "https://github.com/code-yeongyu/asterline-rules",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/code-yeongyu/asterline-rules.git"
	},
	"bugs": {
		"url": "https://github.com/code-yeongyu/asterline-rules/issues"
	},
	"keywords": [
		"asterline",
		"asterline-plugin",
		"rules",
		"hooks",
		"agents-md",
		"context-injection",
		"typescript"
	],
	"bin": {
		"asterline-rules": "./dist/cli.js"
	},
	"files": [
		"bundled-rules",
		"dist",
		"hooks",
		"skills",
		".augment-plugin",
		"LICENSE",
		"NOTICE",
		"README.md",
		"CHANGELOG.md",
		"UPSTREAM-PROVENANCE.json"
	],
	"scripts": {
		"build": "node scripts/build.mjs",
		"test": "vitest --run",
		"test:watch": "vitest",
		"typecheck": "tsc --noEmit",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"check": "tsc --noEmit && biome check . && node scripts/build.mjs"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.16",
		"@types/node": "^25.9.3",
		"@types/picomatch": "^4.0.0",
		"typescript": "^6.0.3",
		"vitest": "^4.1.8"
	},
	"engines": {
		"node": ">=20.0.0"
	}
}
