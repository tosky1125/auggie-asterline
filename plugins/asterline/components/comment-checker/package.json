{
	"name": "@code-yeongyu/asterline-comment-checker",
	"version": "4.17.1",
	"description": "Asterline plugin that runs comment-checker after edit-like PostToolUse hooks.",
	"private": true,
	"type": "module",
	"license": "MIT",
	"homepage": "https://github.com/code-yeongyu/asterline-comment-checker",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/code-yeongyu/asterline-comment-checker.git"
	},
	"bugs": {
		"url": "https://github.com/code-yeongyu/asterline-comment-checker/issues"
	},
	"keywords": [
		"asterline",
		"asterline-plugin",
		"comment-checker",
		"hooks",
		"typescript"
	],
	"bin": {
		"asterline-comment-guard": "./dist/cli.js"
	},
	"files": [
		"dist",
		"hooks",
		"skills",
		".augment-plugin",
		"LICENSE",
		"NOTICE",
		"README.md",
		"CHANGELOG.md"
	],
	"scripts": {
		"build": "node ../../scripts/bundle-component.mjs --source .. --output dist --config runtime/comment-checker.build.json",
		"test": "node --test ../../test/v4171-comment-checker.test.mjs",
		"typecheck": "tsc --noEmit",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"check": "node ../../scripts/bundle-component.mjs --source .. --output dist --config runtime/comment-checker.build.json && node --test ../../test/v4171-comment-checker.test.mjs"
	},
	"engines": {
		"node": ">=20.0.0"
	}
}
